<file path="core/src/main/java/screen/SkillCutsceneScreen.java">
package screen;

import com.badlogic.gdx.Gdx;
import com.badlogic.gdx.Input;
import com.badlogic.gdx.ScreenAdapter;
import com.badlogic.gdx.files.FileHandle;
import com.badlogic.gdx.graphics.GL20;
import com.badlogic.gdx.graphics.g2d.BitmapFont;
import com.badlogic.gdx.graphics.g2d.GlyphLayout;
import com.badlogic.gdx.graphics.glutils.ShapeRenderer;
import com.badlogic.gdx.graphics.Texture;
import com.badlogic.gdx.utils.Array;
import main.Main;
import util.Constants;

import java.nio.file.Path;
import java.nio.file.Paths;
import java.io.File;

public class SkillCutsceneScreen extends ScreenAdapter {
    private final Main game;
    private final ScreenAdapter returnScreen;
    private final String videoAssetPath;
    private final String title;

    private ShapeRenderer shapeRenderer;
    private BitmapFont font;
    private GlyphLayout layout;
    private float elapsed;

    private boolean launchAttempted;
    private boolean launchSucceeded;
    private boolean finished;
    private String debugMessage = "";
    private Array<Texture> frames;
    private float frameDuration;
    private float targetDuration;

    public SkillCutsceneScreen(Main game, ScreenAdapter returnScreen, String videoAssetPath, String title) {
        this.game = game;
        this.returnScreen = returnScreen;
        this.videoAssetPath = videoAssetPath;
        this.title = title;
    }

    @Override
    public void show() {
        shapeRenderer = new ShapeRenderer();
        font = new BitmapFont();
        font.getData().setScale(1.4f);
        layout = new GlyphLayout();
        elapsed = 0f;
        launchCutsceneVideo();
    }

    @Override
    public void render(float delta) {
        elapsed += delta;

        Gdx.gl.glClearColor(0f, 0f, 0f, 1f);
        Gdx.gl.glClear(GL20.GL_COLOR_BUFFER_BIT);

        shapeRenderer.begin(ShapeRenderer.ShapeType.Filled);
        shapeRenderer.setColor(0.05f, 0.05f, 0.05f, 1f);
        shapeRenderer.rect(0, 0, Constants.APP_WIDTH, Constants.APP_HEIGHT);
        shapeRenderer.end();

        game.batch.begin();
        if (launchSucceeded && frames != null && frames.size > 0) {
            int frameIndex = Math.min(frames.size - 1, (int) (elapsed / frameDuration));
            Texture frame = frames.get(frameIndex);
            drawVideoFrame(frame);
        } else {
            drawCentered(title + " CUTSCENE", Constants.APP_HEIGHT * 0.65f);
            if (!launchAttempted) {
                drawCentered("Dang mo video skill...", Constants.APP_HEIGHT * 0.50f);
            } else {
                drawCentered("Khong tim thay hoac khong mo duoc video skill", Constants.APP_HEIGHT * 0.50f);
                drawCentered("Dat file vao assets/videos/skill/", Constants.APP_HEIGHT * 0.44f);
                if (debugMessage != null && !debugMessage.isEmpty()) {
                    drawCentered(debugMessage, Constants.APP_HEIGHT * 0.38f);
                }
            }
        }

        drawCentered("Nhan ENTER/SPACE/ESC de quay lai tran dau", Constants.APP_HEIGHT * 0.30f);
        game.batch.end();

        boolean canSkip = elapsed >= Constants.SKILL_CUTSCENE_MIN_SECONDS;
        if (canSkip && (Gdx.input.isKeyJustPressed(Input.Keys.ENTER)
            || Gdx.input.isKeyJustPressed(Input.Keys.SPACE)
            || Gdx.input.isKeyJustPressed(Input.Keys.ESCAPE))) {
            returnToFight();
            return;
        }

        if (launchSucceeded && elapsed >= targetDuration && canSkip) {
            returnToFight();
            return;
        }

        if (!launchSucceeded && elapsed >= Constants.SKILL_CUTSCENE_AUTO_RETURN_SECONDS) {
            returnToFight();
        }
    }

    private void drawCentered(String text, float y) {
        layout.setText(font, text);
        float x = (Constants.APP_WIDTH - layout.width) / 2f;
        font.draw(game.batch, text, x, y);
    }

    private void returnToFight() {
        if (finished) {
            return;
        }

        finished = true;
        game.setScreen(returnScreen);
        dispose();
    }

    private void launchCutsceneVideo() {
        launchAttempted = true;
        launchSucceeded = false;

        FileHandle framesDir = resolveSkillFrames(videoAssetPath);
        if (framesDir == null || !framesDir.exists() || !framesDir.isDirectory()) {
            debugMessage = "Frames dir not found";
            return;
        }

        try {
            frames = loadFrames(framesDir);
            if (frames == null || frames.isEmpty()) {
                debugMessage = "Khong tim thay frame PNG trong " + framesDir.path();
                return;
            }

            targetDuration = Constants.SKILL_CUTSCENE_TARGET_SECONDS;
            frameDuration = targetDuration / frames.size;
            launchSucceeded = true;
            debugMessage = "Frames: " + frames.size + " @ " + frameDuration + "s";
        } catch (Exception ignored) {
            launchSucceeded = false;
            debugMessage = "Frame load fail";
        }
    }

    private void drawVideoFrame(Texture frame) {
        float targetWidth = Constants.APP_WIDTH;
        float targetHeight = Constants.APP_HEIGHT;
        float frameRatio = frame.getWidth() / (float) frame.getHeight();
        float targetRatio = targetWidth / targetHeight;

        float drawWidth = targetWidth;
        float drawHeight = targetHeight;
        if (frameRatio > targetRatio) {
            drawHeight = targetWidth / frameRatio;
        } else if (frameRatio < targetRatio) {
            drawWidth = targetHeight * frameRatio;
        }

        float x = (targetWidth - drawWidth) * 0.5f;
        float y = (targetHeight - drawHeight) * 0.5f;
        game.batch.draw(frame, x, y, drawWidth, drawHeight);
    }

    private FileHandle resolveSkillFrames(String primaryPath) {
        String framesFolder = buildFramesFolder(primaryPath);
        String[] candidates = buildCandidatePaths(framesFolder);
        for (String candidate : candidates) {
            FileHandle local = Gdx.files.local(candidate);
            if (local.exists()) return local;

            FileHandle absolute = Gdx.files.absolute(candidate);
            if (absolute.exists()) return absolute;

            FileHandle internal = Gdx.files.internal(candidate);
            if (internal.exists()) return internal;
        }

        return null;
    }

    private String buildFramesFolder(String primaryPath) {
        if (primaryPath.contains("skill_p1")) {
            return "videos/skill/p1";
        }
        if (primaryPath.contains("skill_p2")) {
            return "videos/skill/p2";
        }
        return "videos/skill";
    }

    private Array<Texture> loadFrames(FileHandle framesDir) {
        FileHandle[] files = framesDir.list("png");
        if (files == null || files.length == 0) {
            return new Array<>();
        }

        java.util.Arrays.sort(files, java.util.Comparator.comparing(FileHandle::name));
        Array<Texture> loaded = new Array<>(files.length);
        for (FileHandle file : files) {
            loaded.add(new Texture(file));
        }
        return loaded;
    }

    private String[] buildCandidatePaths(String relativeAssetPath) {
        Path userDir = Paths.get(System.getProperty("user.dir")).toAbsolutePath().normalize();
        Path runtimeDir = resolveRuntimeDir();

        return new String[] {
            relativeAssetPath,
            "assets/" + relativeAssetPath,
            userDir.resolve(relativeAssetPath).toString(),
            userDir.resolve("assets").resolve(relativeAssetPath).toString(),
            runtimeDir.resolve(relativeAssetPath).toString(),
            runtimeDir.resolve("assets").resolve(relativeAssetPath).toString()
        };
    }

    private Path resolveRuntimeDir() {
        try {
            Path codePath = Paths.get(SkillCutsceneScreen.class.getProtectionDomain().getCodeSource().getLocation().toURI())
                .toAbsolutePath().normalize();
            return codePath.toFile().isFile() ? codePath.getParent() : codePath;
        } catch (Exception ignored) {
            return new File(".").toPath().toAbsolutePath().normalize();
        }
    }

    @Override
    public void dispose() {
        if (frames != null) {
            for (Texture tex : frames) {
                if (tex != null) tex.dispose();
            }
            frames = null;
        }
        if (shapeRenderer != null) shapeRenderer.dispose();
        if (font != null) font.dispose();
    }
}
