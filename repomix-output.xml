    contents {
      into('libs') {
        project.configurations.runtimeClasspath.files.findAll { file ->
          file.getName() != project.tasks.shadowJar.outputs.files.singleFile.name
        }.each { file ->
          exclude file.name
        }
      }
    }
  }
}

startScripts.dependsOn(':lwjgl3:shadowJar')
startScripts.classpath = project.tasks.shadowJar.outputs.files

if(enableGraalNative == 'true') {
